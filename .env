# Shared configuration inherited by all MCP categories.
# Use this only when running all categories in one workspace.
# For distributed deployment, category .env files are the source of truth.

GLOBAL_REQUEST_TIMEOUT_SECONDS=30
GLOBAL_LOG_LEVEL=INFO

# Optional local-all-in-one defaults (normally set in category .env files):
# RESEARCH_PROVIDER=default
# RESEARCH_API_URL=https://research-provider.example.com/v1/generate
# PLANNER_PROVIDER=default
# EXECUTOR_PROVIDER=default
# PLANNER_AUTH_MODE=api_key
# PLANNER_API_URL=https://planner-provider.example.com/v1/generate
# EXECUTOR_API_URL=https://executor-provider.example.com/v1/generate
# FILESYSTEM_MCP_URL=http://127.0.0.1:8101
# GIT_MCP_URL=http://127.0.0.1:8102
# FILESYSTEM_SERVER_BIND_URL=http://0.0.0.0:8101
# GIT_SERVER_BIND_URL=http://0.0.0.0:8102
